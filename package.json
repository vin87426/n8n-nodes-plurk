{
	"name": "@vin87426/n8n-nodes-plurk",
	"version": "0.1.4",
	"description": "n8n community node for Plurk API 2.0 endpoints.",
	"license": "MIT",
	"homepage": "https://github.com/vin87426/n8n-nodes-plurk#readme",
	"packageManager": "npm@11.14.1",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"n8n-community-node-package",
		"n8n-nodes-plurk"
	],
	"author": {
		"name": "vin87426",
		"email": "vin870426@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/vin87426/n8n-nodes-plurk.git"
	},
	"bugs": {
		"url": "https://github.com/vin87426/n8n-nodes-plurk/issues"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"check": "npm run format:check && npm run lint && npm run build",
		"dev": "n8n-node dev",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist",
		"!dist/.tsbuildinfo",
		"README.md",
		"LICENSE"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PlurkOAuth1Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/Plurk/Plurk.node.js"
		]
	},
	"devDependencies": {
		"@commitlint/cli": "^21.1.0",
		"@commitlint/config-conventional": "^21.1.0",
		"@n8n/node-cli": "^0.37.1",
		"@types/luxon": "^3.7.2",
		"@types/node": "^25.9.3",
		"eslint": "9.29.0",
		"n8n-workflow": "^2.28.1",
		"prettier": "^3.8.4",
		"release-it": "^20.2.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
